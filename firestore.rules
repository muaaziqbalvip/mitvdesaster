rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users, channels, sessions: only accessible to YOUR signed-in admin
    // account (via Firebase Auth email/password), used by admin.html.
    // Your backend (get.py) uses the Admin SDK and always bypasses these
    // rules regardless of what's written here.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /channels/{channelId} {
      allow read, write: if request.auth != null;
    }
    match /movies/{movieId} {
      allow read, write: if request.auth != null;
    }
    match /series/{seriesId} {
      allow read, write: if request.auth != null;
    }
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if false; // sessions are only written by the server (Admin SDK)
    }
  }
}
